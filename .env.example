# OpenFlow environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real API keys.

# Required: Groq API key for Whisper transcription + LLM refinement.
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional overrides (can also be set in ~/.config/openflow/config.toml)
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# GROQ_REFINEMENT_MODEL=llama-3.1-8b-instant
# GROQ_TRANSCRIPTION_LANGUAGE=en
# GROQ_API_BASE=https://api.groq.com/openai/v1
